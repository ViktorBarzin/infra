# devvm Caddyfile — canonical copy: infra/scripts/devvm-caddyfile
# Deploy: sudo install -m 644 scripts/devvm-caddyfile /etc/caddy/Caddyfile && sudo systemctl reload caddy

# Stock default site (unused, kept as installed).
:80 {
	root * /usr/share/caddy
	file_server
}

# learn Viewer — learn.viktorbarzin.me → devvm:7685 (infra/stacks/learn).
# Serves each user's ~/code/learn LIVE, per-user via X-Authentik-Username
# injected by the cluster's authentik-forward-auth middleware. Same
# header-trust model as ttyd :7681 / t3-dispatch (see learn/docs/adr/0001
# in the monorepo).
#
# Authentik usernames are FULL EMAILS (e.g. vbarzin@gmail.com); like
# tmux-attach.sh (`${auth_user%%@*}`) and t3-dispatch we take the local
# part, then map it to the OS user. KEEP THE MAP IN SYNC with
# /etc/ttyd-user-map (generated from roster.yaml — same 3 entries).
# The regex confines the local part to a plain username (no '/', no
# leading dot) so the docroot can't be steered; unmapped users fall
# through to a nonexistent root → 404. The caddy user is in group
# code-shared for wizard's 770 ~/code; other users opt in with
# `chmod o+x ~` (their ~/code is already world-readable).
:7685 {
	@auth header_regexp akuser X-Authentik-Username ^([a-z][a-z0-9._-]{1,64})(@.+)?$
	map {re.akuser.1} {oshome} {
		vbarzin     /home/wizard
		emil.barzin /home/emo
		ancaelena98 /home/ancamilea
		default     /nonexistent
	}
	handle @auth {
		root * {oshome}/code/learn
		file_server browse
	}
	handle {
		respond "Forbidden: missing or invalid X-Authentik-Username" 403
	}
}

        "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
        "query": "label_values(namespace)", "definition": "label_values(namespace)",
        "multi": true, "includeAll": true, "allValue": ".+", "refresh": 2, "sort": 1,
        "current": { "text": "All", "value": "$__all" }

        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "ytd_cash_gross"
            },
            "properties": [
              {
                "id": "custom.thresholdsStyle",
                "value": {
                  "mode": "line"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 12570
                    },
                    {
                      "color": "orange",
                      "value": 50270
                    },
                    {
                      "color": "red",
                      "value": 125140
                    }
                  ]
                }
              }

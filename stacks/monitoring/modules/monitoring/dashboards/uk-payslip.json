  "panels": [
    {
      "id": 1,
      "title": "Tax-year YTD \u2014 gross / net / taxes / RSU / salary",
      "type": "timeseries",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "payslips-pg"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
